{
  "name": "@universal-trust/sdk",
  "version": "0.1.0",
  "description": "SDK for Universal Trust \u2014 Agent identity & trust verification on LUKSO",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "keywords": [
    "lukso",
    "agent",
    "trust",
    "identity",
    "universal-profile",
    "blockchain"
  ],
  "author": "LUKSO Agent",
  "license": "MIT",
  "dependencies": {
    "web3": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}